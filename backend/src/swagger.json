{
  "openapi": "3.0.0",
  "info": {
    "title": "Florio - Flower E-commerce API",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5001/api",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "Đăng ký tài khoản mới",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "username": { "type": "string", "example": "dat_florio" },
                  "email": { "type": "string", "example": "dat@florio.com" },
                  "password": { "type": "string", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Đăng ký thành công." },
          "400": { "description": "Thiếu thông tin hoặc username đã tồn tại." }
        }
      }
    },
    "/auth/signin": {
      "post": {
        "summary": "Đăng nhập và nhận Access Token",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string", "example": "dat_florio" },
                  "password": { "type": "string", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Đăng nhập thành công, trả về accessToken." },
          "401": { "description": "Sai thông tin đăng nhập." }
        }
      }
    },
    "/auth/signout": {
      "post": {
        "summary": "Đăng xuất (xóa refresh token)",
        "tags": ["Authentication"],
        "responses": {
          "204": { "description": "Đăng xuất thành công." }
        }
      }
    },
    "/auth/refresh-token": {
      "post": {
        "summary": "Lấy Access Token mới từ Refresh Token (cookie)",
        "tags": ["Authentication"],
        "responses": {
          "200": { "description": "Trả về accessToken mới." },
          "401": { "description": "Không có refresh token." },
          "403": { "description": "Refresh token không hợp lệ hoặc hết hạn." }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "Lấy danh sách hoa",
        "tags": ["Products"],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer", "default": 10 }
          },
          { "in": "query", "name": "search", "schema": { "type": "string" } },
          { "in": "query", "name": "category", "schema": { "type": "string" } },
          { "in": "query", "name": "minPrice", "schema": { "type": "number" } },
          { "in": "query", "name": "maxPrice", "schema": { "type": "number" } },
          {
            "in": "query",
            "name": "sortBy",
            "schema": {
              "type": "string",
              "enum": ["price_asc", "price_desc", "newest"]
            }
          }
        ],
        "responses": {
          "200": { "description": "Trả về data và pagination." }
        }
      },
      "post": {
        "summary": "Thêm sản phẩm mới (Admin)",
        "tags": ["Products"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "category", "price"],
                "properties": {
                  "name": { "type": "string" },
                  "category": {
                    "type": "string",
                    "description": "MongoDB ObjectId của Category"
                  },
                  "price": { "type": "number" },
                  "tags": { "type": "array", "items": { "type": "string" } },
                  "imageUrl": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tạo sản phẩm thành công." },
          "403": { "description": "Không có quyền Admin." }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Lấy chi tiết một sản phẩm",
        "tags": ["Products"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Tìm thấy sản phẩm." },
          "404": { "description": "Không tìm thấy sản phẩm." }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "Lấy danh sách danh mục",
        "tags": ["Categories"],
        "responses": {
          "200": { "description": "Trả về danh sách categories." }
        }
      },
      "post": {
        "summary": "Tạo danh mục mới (Admin)",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "string", "example": "hoa-tuoi" },
                  "name": { "type": "string", "example": "Hoa Tươi" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tạo danh mục thành công." },
          "403": { "description": "Không có quyền Admin." }
        }
      }
    },
    "/categories/{id}": {
      "get": {
        "summary": "Lấy chi tiết một danh mục",
        "tags": ["Categories"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Tìm thấy danh mục." },
          "404": { "description": "Không tìm thấy danh mục." }
        }
      },
      "put": {
        "summary": "Cập nhật danh mục (Admin)",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Cập nhật thành công." },
          "404": { "description": "Không tìm thấy danh mục." }
        }
      },
      "delete": {
        "summary": "Xóa danh mục (Admin)",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Xóa thành công." },
          "404": { "description": "Không tìm thấy danh mục." }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Tạo đơn hàng mới",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customerName",
                  "phone",
                  "email",
                  "shippingAddress",
                  "items"
                ],
                "properties": {
                  "customerName": {
                    "type": "string",
                    "example": "Nguyễn Văn Đạt"
                  },
                  "phone": { "type": "string", "example": "0901234567" },
                  "email": { "type": "string", "example": "dat@example.com" },
                  "shippingAddress": {
                    "type": "string",
                    "example": "123 Lê Lợi, Q1, TP.HCM"
                  },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "productId": { "type": "string" },
                        "quantity": { "type": "integer", "minimum": 1 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tạo đơn hàng thành công." },
          "401": { "description": "Chưa đăng nhập." }
        }
      },
      "get": {
        "summary": "Lấy toàn bộ đơn hàng (Admin)",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "query",
            "name": "status",
            "schema": {
              "type": "string",
              "enum": [
                "Pending",
                "Processing",
                "Shipped",
                "Delivered",
                "Cancelled"
              ]
            }
          },
          {
            "in": "query",
            "name": "page",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "responses": {
          "200": { "description": "Trả về danh sách đơn hàng và pagination." },
          "403": { "description": "Không có quyền Admin." }
        }
      }
    },
    "/orders/me": {
      "get": {
        "summary": "Lịch sử mua hàng của tôi",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Trả về danh sách đơn hàng của user đang đăng nhập."
          },
          "401": { "description": "Chưa đăng nhập." }
        }
      }
    },
    "/orders/{id}": {
      "put": {
        "summary": "Cập nhật trạng thái đơn hàng (Admin)",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "Pending",
                      "Processing",
                      "Shipped",
                      "Delivered",
                      "Cancelled"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Cập nhật trạng thái thành công." },
          "404": { "description": "Không tìm thấy đơn hàng." }
        }
      }
    }
  }
}
