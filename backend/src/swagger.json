{
  "openapi": "3.0.0",
  "info": {
    "title": "Florio - Flower E-commerce API",
    "version": "1.0.0",
    "description": "Tài liệu API chuẩn RESTful cho dự án bán hoa trực tuyến Florio."
  },
  "servers": [
    {
      "url": "http://localhost:5001/api",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "summary": "Lấy danh sách hoa (Products)",
        "description": "Hỗ trợ tìm kiếm, lọc theo danh mục, khoảng giá, sắp xếp và phân trang.",
        "tags": ["Products"],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Số trang hiện tại"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Số lượng sản phẩm trên mỗi trang"
          },
          {
            "in": "query",
            "name": "search",
            "schema": {
              "type": "string"
            },
            "description": "Tìm kiếm hoa theo tên"
          },
          {
            "in": "query",
            "name": "category",
            "schema": {
              "type": "string"
            },
            "description": "ID của danh mục hoa (ObjectId)"
          },
          {
            "in": "query",
            "name": "minPrice",
            "schema": {
              "type": "number"
            },
            "description": "Giá tối thiểu"
          },
          {
            "in": "query",
            "name": "maxPrice",
            "schema": {
              "type": "number"
            },
            "description": "Giá tối đa"
          },
          {
            "in": "query",
            "name": "sortBy",
            "schema": {
              "type": "string",
              "enum": ["price_asc", "price_desc", "newest"]
            },
            "description": "Kiểu sắp xếp"
          }
        ],
        "responses": {
          "200": {
            "description": "Thành công. Trả về mảng data và thông số pagination."
          },
          "500": {
            "description": "Lỗi server nội bộ."
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Lấy chi tiết một sản phẩm",
        "description": "Trả về thông tin chi tiết của một bó hoa kèm theo thông tin danh mục (Category).",
        "tags": ["Products"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID của sản phẩm (MongoDB ObjectId)"
          }
        ],
        "responses": {
          "200": {
            "description": "Tìm thấy sản phẩm."
          },
          "400": {
            "description": "Định dạng ID không hợp lệ."
          },
          "404": {
            "description": "Không tìm thấy sản phẩm."
          },
          "500": {
            "description": "Lỗi server nội bộ."
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Xác thực người dùng",
        "description": "Đăng nhập và nhận về JWT Access Token.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "user@florio.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "123456"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Đăng nhập thành công, trả về Token."
          },
          "400": {
            "description": "Thiếu email hoặc password."
          },
          "401": {
            "description": "Sai thông tin đăng nhập."
          }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Tạo đơn mua hàng",
        "description": "Gửi thông tin giỏ hàng và địa chỉ giao hàng để tạo đơn. Yêu cầu phải có Access Token.",
        "tags": ["Orders"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "productId": {
                          "type": "string"
                        },
                        "quantity": {
                          "type": "integer",
                          "minimum": 1
                        }
                      }
                    }
                  },
                  "shippingAddress": {
                    "type": "string",
                    "example": "123 Đường Lê Lợi, Quận 1, TP.HCM"
                  },
                  "phone": {
                    "type": "string",
                    "example": "0901234567"
                  }
                },
                "required": ["items", "shippingAddress", "phone"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tạo đơn hàng thành công."
          },
          "401": {
            "description": "Chưa đăng nhập (Thiếu Token)."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
